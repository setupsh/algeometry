  m_Name: 
  m_EditorClassIdentifier: 
  _lessonText:
  - Text: "\u0423\u043C\u043D\u043E\u0436\u043D\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u0441\u0442\u0430\u044F
      \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u044F"
    Prefab: {fileID: 5808118738280883109, guid: 21f07ce681f974ed5b9e8151bb6f4685, type: 3}
    Trigger: {fileID: 0}
  - Text: " \u041D\u043E \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u044B \u043C\u043E\u0433\u0443\u0442
      \u0432\u043E\u0437\u043D\u0438\u043A\u043D\u0443\u0442\u044C \u043A\u043E\u0433\u0434\u0430
      \u043D\u0430\u043C \u043D\u0443\u0436\u043D\u043E \u043A\u043E\u043C\u0431\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435 \u0438 \u0434\u0440\u0443\u0433\u0438\u0435
      \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438"
    Prefab: {fileID: 5808118738280883109, guid: 21f07ce681f974ed5b9e8151bb6f4685, type: 3}
    Trigger: {fileID: 0}
  - Text: "\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440 \u0443\u043C\u043D\u043E\u0436\u0438\u0442\u044C
      \u043D\u0430 \u0441\u0443\u043C\u043C\u0443"
    Prefab: {fileID: 5808118738280883109, guid: 21f07ce681f974ed5b9e8151bb6f4685, type: 3}
    Trigger: {fileID: 981437405}
