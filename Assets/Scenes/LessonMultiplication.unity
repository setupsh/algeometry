  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4fb06526d0a43c5e88d542dd4b970e49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _lessonText:
  - Text: "\u0427\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C \u043E\u0442\u0432\u0435\u0442
      \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441, \u043A\u0430\u043A \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      \u043F\u0435\u0440\u0435\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435 \u0441\u0443\u043C\u043C,
      \u043D\u0430\u043C \u043D\u0430\u0434\u043E \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
      \u043D\u0430 \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435 \u043F\u043E\u0434
      \u0434\u0440\u0443\u0433\u0438\u043C \u0443\u0433\u043B\u043E\u043C, \u0430
      \u0438\u043C\u0435\u043D\u043D\u043E \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u043C"
    Prefab: {fileID: 5808118738280883109, guid: 21f07ce681f974ed5b9e8151bb6f4685, type: 3}
    Trigger: {fileID: 0}
  - Text: "\u0413\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0439
      \u0438\u043D\u0442\u0435\u0440\u043F\u0440\u0438\u0442\u0430\u0446\u0438\u0435\u0439
      \u0443\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u044F \u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F
      \u043F\u0440\u044F\u043C\u043E\u0443\u0433\u043E\u043B\u044C\u043D\u0438\u043A"
    Prefab: {fileID: 5808118738280883109, guid: 21f07ce681f974ed5b9e8151bb6f4685, type: 3}
    Trigger: {fileID: 0}
